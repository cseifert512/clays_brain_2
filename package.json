{
  "name": "latent-visualization",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://YOUR_GITHUB_USERNAME.github.io/YOUR_REPO_NAME",
  "scripts": {
    "dev": "vite --mode clay",
    "dev:atticus": "vite --mode atticus",
    "build": "npm run build:clay",
    "build:clay": "rimraf dist && node scripts/build-site.mjs clay",
    "build:atticus": "rimraf dist && node scripts/build-site.mjs atticus",
    "serve": "vite preview",
    "deploy": "npm run deploy:clay",
    "deploy:clay": "npm run build:clay && gh-pages -d dist -m \"Deploy Clay Seifert site\"",
    "deploy:atticus": "node --env-file=.env.local scripts/deploy-atticus.mjs",
    "caption": "node --env-file=.env.local scripts/caption-portfolio.mjs",
    "build:gallery": "node --env-file=.env.clay scripts/build-gallery.mjs"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@types/three": "^0.176.0",
    "gh-pages": "^6.3.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "gsap": "^3.13.0",
    "three": "^0.176.0"
  }
}
